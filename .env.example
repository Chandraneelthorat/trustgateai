# Backend & worker
DATABASE_URL=postgresql+psycopg://trustgateai:trustgateai@localhost:5432/trustgateai
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
SKIP_CELERY_SYNC=1

# Comma-separated browser origins allowed to call the API.
# "*" is fine locally; in production set your frontend origin, e.g.
# CORS_ORIGINS=https://trustgateai.vercel.app
CORS_ORIGINS=*

# API-key auth (optional). Off by default so local/demo usage stays open.
# Set REQUIRE_API_KEY=true in production to require a key on every non-health endpoint.
# ADMIN_API_KEY is a bootstrap master key used to mint/manage keys via POST /auth/keys.
REQUIRE_API_KEY=false
ADMIN_API_KEY=

# Optional: OpenAI-compatible or HF for DeepEval/RAGAS (leave empty for degraded mode)
OPENAI_API_KEY=
HF_TOKEN=

# Frontend (Next.js public API base)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: key the frontend sends as X-API-Key when the backend requires auth.
NEXT_PUBLIC_API_KEY=
